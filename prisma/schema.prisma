generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id Int @id @default(autoincrement())

  userId String

  company String

  position String

  status String

  dateApplied String

  url String?

  notes String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@index([userId])
  @@index([userId, id])
}

model Contact {
  id Int @id @default(autoincrement())

  name String

  company String

  role String

  type String

  email String?

  notes String?

  createdAt DateTime @default(now())

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId,id])
}

model Task {
  id Int @id @default(autoincrement())

  title String

  description String

  dueDate String

  priority String

  status String

  createdAt DateTime @default(now())

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([userId,id])
}

model Material {

  id Int @id @default(autoincrement())

  name String

  type String

  description String?

  link String?

  source String?

  createdAt DateTime @default(now())

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@index([userId])
  @@index([userId, id])

}

model User {
  id String @id

  name String?

  email String @unique

  createdAt DateTime @default(now())

  jobs Job[]

  contacts Contact[]

  tasks Task[]

  materials Material[]
}

model AIUsage {

id Int @id @default(autoincrement())

userId String

feature String

createdAt DateTime @default(now())

user User @relation(fields:[userId], references:[id], onDelete:Cascade)

}